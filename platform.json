{
  "app": {
    "name": "idea-board",
    "services": {
      "backend":  { "image": "REG/backend",  "port": 8000, "health": "/api/health" },
      "frontend": { "image": "REG/frontend", "port": 80 }
    },
    "database": { "engine": "postgres", "version": "16" }
  },

  "environments": {
    "staging":    { "intent": "cost-sensitive",   "autonomy": "L2" },
    "production": { "intent": "high-availability", "autonomy": "L1" }
  },

  "sizing": {
    "cost-sensitive":    { "node_size": "small",  "db_size": "small",  "replicas": 1, "min_nodes": 1, "max_nodes": 3 },
    "high-availability": { "node_size": "medium", "db_size": "medium", "replicas": 3, "min_nodes": 3, "max_nodes": 6 }
  },

  "contract": { "required_outputs": ["cluster_name"] },

  "providers": {
    "aws": {
      "region":  "ap-south-1",
      "reference": "infra/templates/eks.tf",
      "size_map": { "node": { "small": "t3.small", "medium": "t3.large" } },
      "allowed_resources": [
        "aws_availability_zones", "module.vpc", "module.eks"
      ]
    },
    "gcp": {
      "region":  "asia-south1",
      "zone":    "asia-south1-a",
      "reference": "infra/templates/gke.tf",
      "size_map": { "node": { "small": "e2-small", "medium": "e2-standard-4" } },
      "allowed_resources": [
        "google_compute_network", "google_compute_subnetwork",
        "google_container_cluster", "google_container_node_pool"
      ]
    }
  },

  "policy": {
    "regions_allowed": { "aws": ["ap-south-1", "us-east-1"], "gcp": ["asia-south1", "us-west1", "us-central1"] },
    "max_node_count": 6,
    "db_must_be_private": true,
    "require_tags": ["env", "managed-by"],
    "protect_from_destroy": []
  },

  "agent": {
    "autonomy_default": "L2",
    "canary_percent": 10,
    "error_rate_threshold": 0.02,
    "replica_bounds": [2, 8],
    "max_node_increase": 2,
    "retry_budget": 3,
    "watch_interval_seconds": 60
  },

  "generation": { "temperature": 0, "max_fix_attempts": 3, "model": "gemini-3.6-flash" }
}
